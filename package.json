{
  "name": "traceplay",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered educational SaaS platform with tracing, coloring, and in-world quizzes",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
