    "@types/node": "^20.0.0",
    "@types/passport-jwt": "^3.0.0",
    "@types/passport-local": "^1.0.0",
    "@types/uuid": "^9.0.0",
    "typescript": "^5.3.0",
    "prisma": "^5.0.0"
